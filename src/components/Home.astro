---
import '../styles/global.css'
import LayoutHome from "@/app/layouts/LayoutHome.astro";
---
<LayoutHome>
    <section class="flex flex-col items-center justify-center min-h-screen bg-gray-100">
    <h1 class="text-4xl font-bold text-indigo-600 mb-4">
      Bienvenido a mi sitio en Astro 🚀
    </h1>
    <p class="text-lg text-gray-700 mb-8">
      Este es el componente Home, estilizado con TailwindCSS.
    </p>

    <nav>
      <ul class="flex space-x-6">
        <li>
          <a href="/about" class="text-gray-600 hover:text-indigo-600 transition">
            Sobre mí
          </a>
        </li>
        <li>
          <a href="/projects" class="text-gray-600 hover:text-indigo-600 transition">
            Proyectos
          </a>
        </li>
        <li>
          <a href="/contact" class="text-gray-600 hover:text-indigo-600 transition">
            Contacto
          </a>
        </li>
      </ul>
    </nav>
  </section>
</LayoutHome>

