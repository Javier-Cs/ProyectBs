{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@/componentes/*": ["src/components/*"],
      "@/layouts/*": ["src/app/layouts/*"],
      "@/libs/*": ["src/lib/*"],
      "@/moduls/*": ["src/modules/*"],
      "@/pages/*": ["src/pages/*"],
      "@/types/*": ["src/types/*"],
      "@/util/*": ["src/utils/*"]
      //"@//*": ["src//*"]

    }
  }
}